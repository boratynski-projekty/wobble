# Wobble — zmienne środowiskowe.
# Skopiuj do .env.local (plik jest w .gitignore) i uzupełnij własnymi wartościami.

# Supabase — Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Klucz serwisowy omija RLS. Wyłącznie po stronie serwera (cron zamykający dzień,
# wysyłka pushy). Nigdy z prefiksem NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=

# Web Push (faza 3) — wygeneruj przez: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:

# Chroni endpoint /api/cron/close-day przed wywołaniem z zewnątrz.
CRON_SECRET=
